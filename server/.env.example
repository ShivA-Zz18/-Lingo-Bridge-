# Optional — DigiLocker Sandbox (demo mode if missing)
DIGILOCKER_CLIENT_ID=
DIGILOCKER_CLIENT_SECRET=
DIGILOCKER_REDIRECT_URI=http://localhost:5000/api/digilocker/callback
